<resources xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://developer.garmin.com/downloads/connect-iq/resources.xsd">

    <properties>
        <!-- 0=Current, 1=Workout Average, 2=Round Average, 3=Rolling Average -->
        <property id="mode" type="number">0</property>
        <!-- Duration in seconds for rolling average -->
        <property id="rollingDuration" type="number">30</property>
        <!-- 0=Text (PW/HR), 1=Icon (ϟ♥) -->
        <property id="labelStyle" type="number">0</property>
    </properties>

    <settings>
        <setting propertyKey="@Properties.mode" title="@Strings.modeTitle">
            <settingConfig type="list">
                <listEntry value="0">@Strings.modeCurrent</listEntry>
                <listEntry value="1">@Strings.modeWorkoutAvg</listEntry>
                <listEntry value="2">@Strings.modeRoundAvg</listEntry>
                <listEntry value="3">@Strings.modeRollingAvg</listEntry>
            </settingConfig>
        </setting>

        <setting propertyKey="@Properties.rollingDuration" title="@Strings.rollingDurationTitle">
            <settingConfig type="numeric" min="5" max="300" />
        </setting>

        <setting propertyKey="@Properties.labelStyle" title="@Strings.labelStyleTitle">
            <settingConfig type="list">
                <listEntry value="0">@Strings.labelStyleText</listEntry>
                <listEntry value="1">@Strings.labelStyleIcon</listEntry>
            </settingConfig>
        </setting>
    </settings>

</resources>
